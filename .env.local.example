# ─── REQUIRED — minimal set to boot the app ────────────────────────────────────

# Supabase (database + auth + realtime)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:password@host:5432/postgres

# Anthropic (main agent, expert panel, RAG reranker, classifier)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Voyage (embeddings for RAG — required if you upload any document)
VOYAGE_API_KEY=your-voyage-api-key

# Public app URL (used by Recall.ai webhook callback URL — only matters in visio mode)
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ─── OPTIONAL — features degrade gracefully if these are missing ────────────────

# Live meetings — Deepgram (in-person mic capture)
# DEEPGRAM_API_KEY=your-deepgram-api-key

# Live meetings — Recall.ai (Zoom/Meet/Teams bot for visio)
# RECALL_API_KEY=your-recall-api-key
# RECALL_API_BASE=https://eu-central-1.recall.ai/api/v1

# Deep search agent — OpenRouter gateway to Perplexity Sonar Deep Research
# PERPLEXITY_API_KEY=your-openrouter-api-key

# Data broker — each provider is independent, circuit breaker disables missing ones
# BRAVE_API_KEY=your-brave-api-key
# TAVILY_API_KEY=your-tavily-api-key
# FMP_API_KEY=your-fmp-api-key
# PAPPERS_API_KEY=your-pappers-api-key
# NEWSAPI_API_KEY=your-newsapi-api-key
# PISTE_CLIENT_ID=your-piste-client-id
# PISTE_CLIENT_SECRET=your-piste-client-secret
# FRED_API_KEY=your-fred-api-key

# Data broker — L2 cache (Upstash Redis). Without it, only L1 in-memory cache is used.
# UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Email — Resend via Supabase Edge Functions (requires a verified custom domain)
# RESEND_API_KEY=your-resend-api-key

# Legacy — not used directly, kept for libraries that probe for it
# OPENAI_API_KEY=your-openai-api-key
